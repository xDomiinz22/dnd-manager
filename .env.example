# Postgres (Neon) — endpoint pooled (compatible PgBouncer, con "-pooler")
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dnd_manager?sslmode=require"
# Postgres (Neon) — endpoint directo, sin pooler, usado solo por las migraciones
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/dnd_manager?sslmode=require"

# JWT
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"

# Google Sign-In — Client ID de un OAuth 2.0 Client ID en Google Cloud Console
# (APIs & Services > Credentials). Es público, no un secreto: el mismo valor
# va en GOOGLE_CLIENT_ID (backend, verifica la audience del ID token) y en
# VITE_GOOGLE_CLIENT_ID (frontend, inicializa el botón de Google).
GOOGLE_CLIENT_ID=""
VITE_GOOGLE_CLIENT_ID=""

# Vercel Blob
BLOB_READ_WRITE_TOKEN=""

NODE_ENV="development"
PORT="3001"
