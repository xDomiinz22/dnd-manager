generator client {
  provider      = "prisma-client-js"
  // Ubicación por defecto (node_modules/.prisma/client): es la mejor soportada
  // por el node-file-tracing de Vercel. binaryTargets incluye el engine de
  // Linux que usa el runtime serverless además del nativo para desarrollo.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  // Null para cuentas creadas exclusivamente vía Google Sign-In.
  passwordHash String?
  googleId     String?  @unique
  avatarUrl    String?
  createdAt    DateTime @default(now())

  ownedGroups Group[]          @relation("GroupMaster")
  memberships GroupMember[]
  characters  CharacterSheet[]
  assets      Asset[]
  addedTracks MusicTrack[]     @relation("MusicTrackAddedBy")
  diceRolls   DiceRoll[]
}

model Group {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  masterId   String
  master     User     @relation("GroupMaster", fields: [masterId], references: [id])
  createdAt  DateTime @default(now())

  members        GroupMember[]
  characters     CharacterSheet[]
  groupJournal   JournalEntry?    @relation("GroupJournal")
  musicPlaylists MusicPlaylist[]
  map            GroupMap?
  diceRolls      DiceRoll[]
}

enum GroupRole {
  MASTER
  PLAYER
}

model GroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  role     GroupRole @default(PLAYER)
  joinedAt DateTime  @default(now())

  // El Master siempre puede gestionar la música ambiente del grupo; este
  // campo concede el mismo permiso a un jugador concreto (o a todos, si el
  // Master lo activa en cada uno). No afecta a nada más.
  canEditMusic Boolean @default(false)

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

// Música ambiente por grupo: listas temáticas (p.ej. "Taberna", "Combate")
// con tracks que apuntan a un vídeo de YouTube (solo se reproduce el audio,
// nunca se descarga ni se guarda el contenido — ver README).
model MusicPlaylist {
  id      String @id @default(cuid())
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  name      String
  order     Int      @default(0)
  // Si está activo, cualquier miembro del grupo (no solo Master/canEditMusic)
  // puede añadir tracks a esta lista — como una cola colaborativa de Spotify.
  // Borrar/renombrar la lista y borrar tracks ajenos sigue restringido.
  openToAll Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tracks MusicTrack[]
}

model MusicTrack {
  id         String        @id @default(cuid())
  playlistId String
  playlist   MusicPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  title     String
  // ID de 11 caracteres del vídeo de YouTube (no la URL cruda; se normaliza
  // al añadir el track, ver shared/src/music.ts → extractYoutubeId).
  youtubeId String
  order     Int      @default(0)
  // Si está activo, al terminar este track se repite solo en vez de avanzar
  // al siguiente (aunque el botón manual "siguiente" sí lo salta). Es una
  // preferencia de escucha compartida por todo el grupo, no una edición de
  // contenido — cualquier miembro puede tocarla.
  loop      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Quién lo añadió (null en tracks ya existentes antes de este campo).
  // Permite que un jugador sin canEditMusic borre lo que él mismo añadió a
  // una lista abierta, aunque no pueda tocar lo de los demás.
  addedByUserId String?
  addedBy       User?   @relation("MusicTrackAddedBy", fields: [addedByUserId], references: [id], onDelete: SetNull)
}

enum AssetKind {
  IMAGE
  PDF
  OTHER
}

model Asset {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation(fields: [ownerId], references: [id])
  kind         AssetKind
  // Bytes del archivo guardados en Postgres (modo Neon-only). Si en el futuro
  // se activa Vercel Blob, `data` queda null y `url` apunta al Blob real.
  data         Bytes?
  storageKey   String?
  url          String?
  mime         String
  size         Int
  originalName String?
  createdAt    DateTime  @default(now())

  // Retrato activo de estos personajes (Asset.kind = IMAGE)
  portraitOf CharacterSheet[] @relation("CharacterPortrait")

  // Galería de imágenes subidas para un personaje (atuendos, etc.); portraitOf
  // apunta a cuál de estas está activa como retrato principal.
  characterId String?
  character   CharacterSheet? @relation("CharacterImages", fields: [characterId], references: [id])

  // Embeds ![[...]] resueltos en páginas de journal
  journalPageAssets JournalPageAsset[]

  // Imagen actual del mapa de un grupo (Asset.kind = IMAGE). Cada subida crea
  // un Asset nuevo (el anterior queda huérfano, igual que al cambiar retrato).
  groupMap GroupMap?
}

model CharacterSheet {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // Columnas indexadas para listados / cabecera:
  name         String
  level        Int     @default(1)
  className    String?
  subclassName String?
  species      String?
  background   String?
  alignment    String?

  portraitAssetId String?
  portraitAsset   Asset?  @relation("CharacterPortrait", fields: [portraitAssetId], references: [id])
  images          Asset[] @relation("CharacterImages")

  // PG actuales editables en vivo (registrar daño/curación). Null = todavía no
  // se ha tocado manualmente, y se usa el valor importado del .md / el máximo.
  currentHp Int?

  // Huecos de conjuro nivel 1-7: cuántos se han gastado hoy y cuántos hay como
  // máximo. Null = todavía no se ha tocado, se usa el default (0 usados / 4
  // máximo) porque el .md de Foundry no trae el máximo real de forma fiable.
  spellSlots Json?

  // Datos crudos y derivados:
  rawSystem    Json
  items        Json
  derived      Json?
  sourceMdHash String?

  personalJournal JournalEntry? @relation("CharacterJournal")
  diceRolls       DiceRoll[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, groupId, name])
}

enum JournalScope {
  GROUP
  CHARACTER
}

model JournalEntry {
  id    String       @id @default(cuid())
  scope JournalScope
  title String

  groupId String? @unique
  group   Group?  @relation("GroupJournal", fields: [groupId], references: [id], onDelete: Cascade)

  characterId String?         @unique
  character   CharacterSheet? @relation("CharacterJournal", fields: [characterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  pages JournalPage[]
}

model JournalPage {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  parentId String?
  parent   JournalPage?  @relation("PageTree", fields: [parentId], references: [id])
  children JournalPage[] @relation("PageTree")

  title        String
  bodyMarkdown String  @db.Text
  order        Int     @default(0)
  foundryId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets   JournalPageAsset[]
  linksOut JournalPageLink[]  @relation("LinkFrom")
  linksIn  JournalPageLink[]  @relation("LinkTo")
  mapPins  MapPin[]
}

model JournalPageAsset {
  id      String      @id @default(cuid())
  pageId  String
  page    JournalPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  assetId String
  asset   Asset       @relation(fields: [assetId], references: [id])
  order   Int         @default(0)
}

model JournalPageLink {
  id         String  @id @default(cuid())
  fromPageId String
  toPageId   String
  label      String?

  fromPage JournalPage @relation("LinkFrom", fields: [fromPageId], references: [id], onDelete: Cascade)
  toPage   JournalPage @relation("LinkTo", fields: [toPageId], references: [id], onDelete: Cascade)
}

// Mapa de campaña por grupo: una sola imagen "actual" (se va reemplazando a
// medida que el Master revela más terreno) más pines de posición fija que
// sobreviven a esos reemplazos. Solo se guarda el estado actual, sin
// histórico de versiones anteriores (decisión confirmada con el usuario).
model GroupMap {
  id      String @id @default(cuid())
  groupId String @unique
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  assetId String @unique
  asset   Asset  @relation(fields: [assetId], references: [id])
  // Dimensiones en px de la imagen actual, capturadas en la subida: toda
  // imagen de reemplazo debe medir exactamente esto (ver mapService), para
  // que los MapPin (posición relativa 0-1) no queden descuadrados.
  width  Int
  height Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pins MapPin[]
}

model MapPin {
  id         String   @id @default(cuid())
  groupMapId String
  groupMap   GroupMap @relation(fields: [groupMapId], references: [id], onDelete: Cascade)

  // Posición relativa (0-1, no píxeles) para que sobreviva a un reemplazo de
  // la imagen de fondo mientras mantenga las mismas dimensiones.
  x Float
  y Float

  title String

  // Enlace opcional a una página del diario DE GRUPO (no de personaje) para
  // el "leer más" del popup del pin.
  journalPageId String?
  journalPage   JournalPage? @relation(fields: [journalPageId], references: [id], onDelete: SetNull)

  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Log compartido de tiradas de dados por grupo (tiradas de salvación, ataques,
// daño...). La tirada la calcula el servidor (nunca se confía en un resultado
// mandado por el cliente); characterId es opcional y nullable-on-delete para
// que el registro sobreviva si el personaje se borra más tarde.
model DiceRoll {
  id      String @id @default(cuid())
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  characterId String?
  character   CharacterSheet? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  label    String
  formula  String
  // Desglose por dado: [{ "die": "1d20", "values": [14] }, ...]
  rolls    Json
  modifier Int
  total    Int

  createdAt DateTime @default(now())

  @@index([groupId, createdAt])
}
